# --- Base game (DO NOT COMMIT — third-party / copyrighted) ---------------------
# The full "Another Red" game copy used as the bake target, and the decompiled
# base-game Ruby scripts kept locally for reference. Neither is ours to publish.
/tmp/
/decompiled/

# --- Local tool / session state ----------------------------------------------
.claude/
*.log
*.clog

# --- Backups & generated artifacts -------------------------------------------
*.bak
*.tmp
*.orig

# --- Release artifacts (DO NOT COMMIT) ---------------------------------------
# build_release.py bundles the FULL baked PluginScripts.rxdata (the 29 base-game
# plugins + our plugin) plus audio. That base-game content is third-party and the
# zip is large — it belongs on GitHub Releases as an asset, never in git history.
/dist/*.zip

# --- Python (baker tooling) --------------------------------------------------
__pycache__/
*.pyc

# --- Node (relay server) -----------------------------------------------------
node_modules/
npm-debug.log*

# --- OS cruft ----------------------------------------------------------------
Thumbs.db
desktop.ini
.DS_Store
*~

# --- Agent-facing docs -------------------------------------------------------
# Internal design/protocol/deploy notes written for the coding agent to read.
# README.md files stay tracked; every other *.md is kept out of the repo.
*.md
!README.md

