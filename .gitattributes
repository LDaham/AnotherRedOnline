# Normalize text, but NEVER touch binaries (element.bin / audio must stay exact).
* text=auto

*.rb   text eol=lf
*.py   text eol=lf
*.js   text eol=lf
*.md   text eol=lf
*.json text eol=lf

# Windows launcher scripts want CRLF.
*.ps1  text eol=crlf
*.bat  text eol=crlf

# Binary payloads — no EOL conversion, no diffing.
*.bin    binary
*.ogg    binary
*.rxdata binary
*.png    binary
